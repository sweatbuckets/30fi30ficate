{
  "manifest_version": 2,
  "name": "30ficate",
  "version": "0.1.0",
  "description": "On-chain TLS certificate verification guard for Firefox.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["dist/background/index.js"]
  },
  "icons": {
    "48": "assets/icons/3030icon.svg",
    "96": "assets/icons/3030icon.svg"
  },
  "browser_action": {
    "default_title": "30ficate",
    "default_popup": "dist/popup/index.html",
    "default_icon": {
      "16": "assets/icons/3030icon.svg",
      "32": "assets/icons/3030icon.svg"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "30ficate@example.com",
      "strict_min_version": "109.0"
    }
  }
}
