{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "types": ["firefox-webext-browser"]
  },
  "include": ["src/**/*.ts"]
}
